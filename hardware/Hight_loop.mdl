  chart {
    id			    2
    machine		    1
    name		    "PD Control & VMC/Virtual model control (VMC)"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 3 0 0]
    viewObj		    2
    ssIdHighWaterMark	    13
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    1
    disableImplicitCasting  1
    eml {
      name		      "fcn"
    }
    firstData		    4
    firstTransition	    14
    firstJunction	    13
  }
  state {
    id			    3
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    2
    treeNode		    [2 0 0 0]
    superState		    SUBCHART
    subviewer		    2
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function [T_link2, l5] = fcn(F0, theta1, l1, l2, l3, l4, l23)\n\n    l5 = sqrt(l2^2 + l4^2 - 2*l2"
      "*l4*cos(theta1 + pi/4));\n\n    % Calculate internal geometric angles (Alpha and Beta)\n    % Alpha corresponds "
      "to theta2 and Beta to theta3.\n    alpha_val = asin((l4 * sin(theta1 + pi/4)) / l5);\n    \n    % Argument for a"
      "cos must be clamped to [-1, 1] to prevent complex numbers.\n    cos_beta_arg = (l23^2 + l5^2 - l3^2) / (2 * l23 "
      "* l5);\n    cos_beta_arg = max(min(cos_beta_arg, 1), -1);\n    beta_val = acos(cos_beta_arg);\n\n    % J1 maps t"
      "he vertical force F0 to the torque at the primary joint.\n    J1 = l2 * cos(theta1) + l1 * cos(theta1 + alpha_va"
      "l + beta_val);\n    T_link2 = F0 * J1;\n\nend"
    }
  }
  data {
    id			    4
    ssIdNumber		    4
    name		    "F0"
    scope		    INPUT_DATA
    machine		    1
    props {
