    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function theta_final = fcn(theta_cmd, torque_vmc, joint_stiffness)\n\n    % Delta_theta represent"
      "s how much the joint \"gives\" under torque.\n    % Higher joint_stiffness makes the leg feel more rigid.\n    d"
      "elta_theta = torque_vmc / joint_stiffness;\n\n    theta_final = theta_cmd + delta_theta;\n\nend"
    }
  }
