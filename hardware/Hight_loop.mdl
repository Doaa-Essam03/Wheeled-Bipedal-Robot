  chart {
    id			    46
    machine		    1
    name		    "Leg kinematics"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 47 0 0]
    viewObj		    46
    ssIdHighWaterMark	    16
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    5
    disableImplicitCasting  1
    eml {
      name		      "fcn"
    }
    firstData		    48
    firstTransition	    62
    firstJunction	    61
  }
  state {
    id			    47
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    46
    treeNode		    [46 0 0 0]
    superState		    SUBCHART
    subviewer		    46
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function [lleg, L0, lw] = fcn(theta1, l1, l2, l3, l4, l23, m1, m2, m3, m23)\n    \n    \n    l5 ="
      " sqrt(l2^2 + l4^2 - 2 * l2 * l4 * cos(theta1 + pi/4));\n    theta2 = asin((l4 * sin(theta1 + pi/4)) / l5);\n    "
      "theta3 = acos((l23^2 + l5^2 - l3^2) / (2 * l23 * l5));\n    theta4 = pi - theta1 - theta2 - theta3;\n    theta5 "
      "= pi - theta4;\n    theta6 = asin((l5 * sin(theta3)) / l3) - theta4;\n    \n\n    lleg = l2 * sin(theta1) + l1 *"
      " sin(theta4);\n    \n   \n    xc2 = (l2 * sin(theta1)) / 2;\n    xc1 = l2 * sin(theta1) + (l1 * sin(theta5)) / 2"
      ";\n    xc3 = -l4 * sin(pi/4) + (l3 * sin(theta6)) / 2;\n    xc23 = l2 * sin(theta1) - (l23 * sin(theta4)) / 2;\n"
      "    \n\n    L0 = (m1*xc1 + m2*xc2 + m3*xc3 + m23*xc23) / (m1 + m2 + m3 + m23);\n    \n   \n    lw = lleg - L0;\n"
      "    \nend"
    }
  }
